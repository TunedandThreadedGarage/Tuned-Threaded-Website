# Copy to .env.local for local development.
# Never commit .env.local.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: look up recipient emails for activity notifications
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM="Tuned & Threaded <hello@yourdomain.com>"

# Shopify (Dev Dashboard — Client Credentials OAuth)
# Dev Dashboard → App → Settings → Client ID + Client secret
# App must be installed on the store (same organization).
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Alternate: SHOPIFY_SHOP=your-store
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Optional: featured collection handle for the home Shop section
SHOPIFY_FEATURED_COLLECTION=
